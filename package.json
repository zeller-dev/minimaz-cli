{
    "name": "minimaz-cli",
    "version": "0.4.1",
    "description": "Minimal project initializer and builder CLI",
    "author": "MrZeller",
    "license": "MIT",
    "type": "module",
    "files": [
        "bin",
        "templates",
        "LICENSE",
        "README.md",
        "package.json"
    ],
    "keywords": [
        "cli",
        "minimal",
        "build",
        "init",
        "project",
        "starter"
    ],
    "scripts": {
        "dev": "tsx bin/cli.ts",
        "build": "tsc --noEmit && node builder.js",
        "build:dev": "tsc --noEmit && cross-env NODE_ENV=development node builder.js",
        "postinstall:dev": "tsx ./src/utils/postInstall.ts",
        "postinstall:prod": "node dist/src/utils/postInstall.js"
    },
    "bin": {
        "minimaz": "dist/bin/cli.js",
        "mz": "dist/bin/cli.js"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/zeller-dev/minimaz-cli.git"
    },
    "homepage": "https://github.com/zeller-dev/minimaz-cli#readme",
    "bugs": {
        "url": "https://github.com/zeller-dev/minimaz-cli/issues"
    },
    "dependencies": {
        "cross-spawn": "^7.0.6",
        "esbuild": "^0.25.12",
        "fs-extra": "^11.3.0",
        "html-minifier-terser": "^7.2.0"
    },
    "devDependencies": {
        "@types/cross-spawn": "^6.0.6",
        "@types/fs-extra": "^11.0.4",
        "@types/html-minifier-terser": "^7.0.2",
        "@types/node": "^24.7.2",
        "cross-env": "^10.1.0",
        "tsx": "^4.21.0",
        "typescript": "^5.9.3"
    },
    "postinstall": "node dist/bin/cli.js"
}